RewriteEngine On

# Default page: index.php (so / loads index.php without showing filename)
DirectoryIndex index.php

# /watch?v=VIDEO_ID → ver.php
RewriteRule ^watch$ ver.php [QSA,L]

# /canal?id=ID → canal.php
RewriteRule ^canal$ canal.php [QSA,L]

# /peliculas → peliculas.php
RewriteRule ^peliculas$ peliculas.php [QSA,L]

# /landing → landing.php
RewriteRule ^landing$ landing.php [L]
