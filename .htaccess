RewriteEngine On

# Default page: index.php (so / loads index.php without showing filename)
DirectoryIndex index.php

# /watch?v=VIDEO_ID → ver.php
RewriteRule ^watch$ ver.php [QSA,L]

# /canal?id=ID → canal.php
RewriteRule ^canal$ canal.php [QSA,L]

# /videos → videos.php
RewriteRule ^videos$ videos.php [QSA,L]

# /cine → cine.php
RewriteRule ^cine$ cine.php [QSA,L]

# /audiolibros → audiolibros.php
RewriteRule ^audiolibros$ audiolibros.php [QSA,L]

# /libros → libros.php
RewriteRule ^libros$ libros.php [QSA,L]

# /novedades → novedades.php
RewriteRule ^novedades$ novedades.php [QSA,L]

# /leer?id=X → leer.php
RewriteRule ^leer$ leer.php [QSA,L]

# /peliculas and /documentales → redirect to /cine
RewriteRule ^peliculas$ cine [R=301,L]
RewriteRule ^documentales$ cine [R=301,L]

# /landing → landing.php
RewriteRule ^landing$ landing.php [L]
